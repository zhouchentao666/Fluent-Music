{
  "name": "fluent-music",
  "version": "1.0.0",
  "description": "Local music player with Fluent Design",
  "main": "electron/main.js",
  "scripts": {
    "start": "react-scripts start",
    "electron": "electron .",
    "build": "react-scripts build",
    "electron-build": "npm run build && electron-builder",
    "dev": "concurrently \"npm run start\" \"wait-on http://localhost:3000 && electron .\""
  },
  "build": {
    "appId": "com.fluentmusic.app",
    "productName": "FluentMusic",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "music-metadata": "^7.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "react-windows-ui": "^4.2.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  }
}
